# Copia como .env y actualiza valores para tu entorno

# Etiqueta para imágenes Docker (build/push)
TAG=latest

# Entorno
NODE_ENV=production

# Puertos (lado host)
PS_PORT=3001
SECURITY_PORT=3002
API_PORT=4000
WEB_PORT=8080

# Mongo
MONGO_URI=mongodb://mongo:27017/BD_Diagnostico_Rendimiento

# Redis (deshabilitado por defecto)
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379

# PageSpeed API key (requerida si usas API oficial; si falta, se usa Lighthouse local)
PSI_API_KEY=AIzaSyC_0_KjQKRPME_GayWYQW0ZQaK9eEsT5P4

# Base URL de la app (opcional, usado en logs/enlaces del servidor)
APP_BASE_URL=http://localhost:8080

# Correo para envío de informes (Gmail SMTP)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password-de-gmail

# --- SSO DATALAKE (Frontend) ---
# Endpoints corporativos
VITE_PROT_DATALAKE=http
VITE_HOST_DATALAKE=172.17.46.159
# Se incluye el ':' porque el servicio expone puerto 9080
VITE_PORT_DATALAKE=:9080
# Alias para tolerar el typo previo
VITE_PORT_DATALKE=:9080
VITE_LOGIN_DATALAKE=/datalake/login
VITE_GETDATA_DATALAKE=/datalake/api/authorize
