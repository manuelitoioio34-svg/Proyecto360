{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.ts",
    "dev:4g": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsx watch index.ts",
    "start": "node dist/index.js",
    "worker:dev": "cross-env DOTENV_CONFIG_PATH=server/.env tsx src/pagespeed.worker.ts",
    "build": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "@mdn/browser-compat-data": "^5.6.38",
    "axe-core": "^4.9.1",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.4",
    
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^7.0.0",
    "nodemon": "^3.1.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
